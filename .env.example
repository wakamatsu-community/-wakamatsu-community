# ---------------------------------------------------------------
# Python fetch_calendar.py 用 .env サンプル
# このファイルをコピーして ".env" にリネームし、実際の値を入力してください。
# .env は絶対に Git にコミットしないでください（.gitignore で除外済み）。
# ---------------------------------------------------------------

# 現在の運用では GAS Webアプリ URL を使用
GAS_WEB_APP_URL=https://script.google.com/macros/s/your-deployed-web-app-id/exec
# 参考: フロントで Google Calendar API を直接使う場合のみ設定
# GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# フロントで Firestore を直接読む場合に必要
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
# FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# 互換用: サービスアカウント方式を使う場合のみ設定
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/service_account.json
